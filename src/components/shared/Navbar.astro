---
interface Props {
  theme?: 'dark' | 'light';
}

const { theme = 'dark' } = Astro.props;
const currentPath = Astro.url.pathname;

const isDark = theme === 'dark';
const bg = isDark ? 'rgba(13,13,11,0.9)' : 'rgba(250,247,241,0.93)';
const text = isDark ? '#E8E4DF' : '#1a1a1a';
const muted = isDark ? 'rgba(232,228,223,0.4)' : 'rgba(26,26,26,0.45)';
const border = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(26,26,26,0.08)';
const cartBg = isDark ? 'rgba(196,160,112,0.12)' : 'rgba(196,160,112,0.15)';
const cartBorder = isDark ? 'rgba(196,160,112,0.25)' : 'rgba(196,160,112,0.3)';
const cartColor = isDark ? '#C4A070' : '#8B6D4F';

const links = [
  { href: '/', label: 'Home' },
  { href: '/casa', label: 'Casa' },
  { href: '/studio', label: 'Studio' },
  { href: '/threads', label: 'Threads' },
  { href: '/about', label: 'About' },
];

const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header id="main-nav" style={`position:sticky;top:0;z-index:100;background:${bg};backdrop-filter:blur(18px) saturate(1.4);border-bottom:1px solid ${border};`}>
  <div class="container" style="height:64px;display:flex;align-items:center;justify-content:space-between;">
    
    <!-- Logo -->
    <a href="/" style="display:flex;align-items:center;gap:10px;">
      <img src="/images/baja-logo.png" alt="Baja Works Logo" style="height:28px;">
      <span style={`font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:2.5px;color:${text};`}>BAJA WORKS CO.</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="desktop-nav" style="display:flex;align-items:center;gap:2px;">
      {links.map(l => (
        <a
          href={l.href}
          aria-current={isActive(l.href) ? 'page' : undefined}
          style={`padding:7px 13px;border-radius:5px;font-family:'Outfit',sans-serif;font-size:12.5px;letter-spacing:1px;text-transform:uppercase;font-weight:400;color:${isActive(l.href) ? text : muted};transition:color 0.2s;`}
        >{l.label}</a>
      ))}
      <div style={`width:1px;height:18px;background:${border};margin:0 6px;`}></div>
      <a
        href="/contact"
        style={`padding:7px 13px;font-family:'Outfit',sans-serif;font-size:12.5px;letter-spacing:1px;text-transform:uppercase;font-weight:400;color:${isActive('/contact') ? text : muted};`}
      >Contact</a>
      <a
        href="/cart"
        id="cart-nav-btn"
        style={`margin-left:6px;padding:7px 14px;border-radius:5px;font-family:'Outfit',sans-serif;font-size:12.5px;letter-spacing:1px;text-transform:uppercase;font-weight:500;background:${cartBg};border:1px solid ${cartBorder};color:${cartColor};display:flex;align-items:center;gap:8px;`}
      >
        Cart
        <span id="cart-count" style="display:none;background:#E8753A;color:#fff;border-radius:50%;width:18px;height:18px;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;">0</span>
      </a>
    </nav>

    <!-- Mobile Controls -->
    <div class="mobile-controls" style="display:none;align-items:center;gap:8px;">
      <a href="/cart" class="mobile-cart-btn" style={`display:none;color:${text};font-size:13px;font-family:'Outfit',sans-serif;letter-spacing:1px;padding:6px 10px;`}>
        Cart <span id="cart-count-mobile" style="display:none;"></span>
      </a>
      <button id="mobile-toggle" class="mobile-menu-btn" style={`display:none;background:none;border:none;cursor:pointer;padding:6px;color:${text};font-size:22px;`}>☰</button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu" style={`display:none;position:absolute;top:64px;left:0;right:0;background:${isDark ? '#0D0D0B' : '#FAF7F1'};border-bottom:1px solid ${border};padding:16px clamp(18px,4vw,40px);z-index:99;`}>
    {[...links, { href: '/contact', label: 'Contact' }].map(l => (
      <a
        href={l.href}
        style={`display:block;padding:12px 0;font-family:'Outfit',sans-serif;font-size:15px;letter-spacing:1px;text-transform:uppercase;color:${isActive(l.href) ? text : muted};border-bottom:1px solid ${border};`}
      >{l.label}</a>
    ))}
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.style.display === 'flex';
      menu.style.display = open ? 'none' : 'flex';
      menu.style.flexDirection = 'column';
      toggle.textContent = open ? '☰' : '✕';
    });
  }
</script>
