---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import RevealScript from '../components/shared/RevealScript.astro';
import CartDrawer from '../components/shared/CartDrawer.tsx';
import '../styles/global.css';
---

<BaseLayout title="BAJA WORKS CO." description="Creative manufacturing studio — handcrafted goods, design, and apparel. Made in San Diego.">
  <Navbar theme="dark" />
  <CartDrawer client:load />

  <!-- Grain -->
  <div class="grain"></div>

  <!-- ═══ HERO ═══ -->
  <section style="position:relative;overflow:hidden;min-height:min(88vh,720px);display:flex;align-items:center;border-bottom:1px solid rgba(255,255,255,0.05);">
    <!-- BG gradients -->
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse 800px 450px at 12% 35%,rgba(196,160,112,0.07),transparent 55%),radial-gradient(ellipse 600px 350px at 88% 65%,rgba(139,109,79,0.05),transparent 55%);"></div>
    <!-- Decorative lines -->
    <div style="position:absolute;top:38%;left:0;right:0;height:1px;background:rgba(196,160,112,0.04);"></div>
    <div style="position:absolute;top:62%;left:0;right:0;height:1px;background:rgba(196,160,112,0.03);"></div>

    <div class="container" style="position:relative;z-index:2;padding-top:80px;padding-bottom:80px;width:100%;">
      <div class="label-accent reveal" style="margin-bottom:28px;">
        Creative Manufacturing Studio
      </div>

      <h1 class="heading-xl reveal reveal-d1">
        BAJA<br /><span style="color:rgba(232,228,223,0.3);">WORKS CO.</span>
      </h1>

      <p class="reveal reveal-d2" style="font-size:clamp(15px,1.8vw,19px);line-height:1.65;color:rgba(232,228,223,0.45);max-width:46ch;margin-top:30px;font-weight:300;">
        We design and build goods by hand — home pieces, custom fabrications, graphic prints, and apparel. Every product starts as an idea in our workshop and ends up in yours.
      </p>

      <div class="reveal reveal-d3" style="display:flex;gap:14px;margin-top:36px;flex-wrap:wrap;">
        <a href="/casa" class="btn-primary">Shop Casa</a>
        <a href="/studio" class="btn-outline">Baja Studio</a>
      </div>
    </div>
  </section>

  <!-- ═══ DIVISIONS ═══ -->
  <section class="section" style="border-bottom:1px solid rgba(255,255,255,0.05);">
    <div class="container">
      <div class="label-sm reveal">Our Divisions</div>
      <h2 class="heading-lg reveal reveal-d1" style="margin-bottom:44px;">Design. Fabricate. Build.</h2>

      <div class="grid-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
        <a href="/casa" class="division-card reveal">
          <div>
            <div style="font-size:11px;color:#C4A070;letter-spacing:2px;margin-bottom:14px;font-weight:500;">01</div>
            <h3 style="font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:2px;margin:0 0 12px;">Casa Baja</h3>
            <p style="font-size:13.5px;line-height:1.7;color:rgba(232,228,223,0.4);margin:0;">Handcrafted goods for home, kids, pets, and gifting. Coasters, clocks, organizers, charcuterie boards — made from wood, metal, and real materials.</p>
          </div>
          <div style="margin-top:22px;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#C4A070;display:flex;align-items:center;gap:8px;">Explore <span style="font-size:15px;">→</span></div>
        </a>

        <a href="/studio" class="division-card reveal reveal-d1">
          <div>
            <div style="font-size:11px;color:#E8753A;letter-spacing:2px;margin-bottom:14px;font-weight:500;">02</div>
            <h3 style="font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:2px;margin:0 0 12px;">Baja Studio</h3>
            <p style="font-size:13.5px;line-height:1.7;color:rgba(232,228,223,0.4);margin:0;">Visual and print work — posters, banners, canvas art, photo collages, branding packages, stickers, and event graphics.</p>
          </div>
          <div style="margin-top:22px;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#E8753A;display:flex;align-items:center;gap:8px;">Explore <span style="font-size:15px;">→</span></div>
        </a>

        <a href="/threads" class="division-card reveal reveal-d2">
          <div>
            <div style="font-size:11px;color:#8B9E6B;letter-spacing:2px;margin-bottom:14px;font-weight:500;">03</div>
            <h3 style="font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:2px;margin:0 0 12px;">Baja Threads</h3>
            <p style="font-size:13.5px;line-height:1.7;color:rgba(232,228,223,0.4);margin:0;">Minimal streetwear rooted in desert culture. T-shirts, hoodies, hats, and limited drops. Coming soon.</p>
          </div>
          <div style="margin-top:22px;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#8B9E6B;display:flex;align-items:center;gap:8px;">Explore <span style="font-size:15px;">→</span></div>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ BRAND STATEMENT ═══ -->
  <section style="padding:100px 0;position:relative;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse 700px 350px at 50% 50%,rgba(196,160,112,0.035),transparent 65%);"></div>
    <div style="max-width:780px;margin:0 auto;padding:0 clamp(18px,4vw,40px);text-align:center;position:relative;">
      <div class="reveal">
        <div style="width:44px;height:1px;background:#C4A070;margin:0 auto 30px;"></div>
        <blockquote style="font-family:'Bebas Neue',sans-serif;font-size:clamp(22px,3.8vw,40px);letter-spacing:2.5px;line-height:1.25;color:rgba(232,228,223,0.75);margin:0;">
          "We don't just make things —<br />we make things that matter."
        </blockquote>
        <p style="font-size:14.5px;line-height:1.85;color:rgba(232,228,223,0.3);margin-top:28px;max-width:50ch;margin-left:auto;margin-right:auto;">
          Every piece that leaves our workshop carries something real — the grain of the wood, the precision of the cut, the thought behind the design. We build for people who care about what they surround themselves with.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ PROCESS ═══ -->
  <section class="section-sm" style="border-top:1px solid rgba(255,255,255,0.05);border-bottom:1px solid rgba(255,255,255,0.05);background:rgba(196,160,112,0.02);">
    <div class="container">
      <div class="grid-4" style="display:grid;grid-template-columns:repeat(4,1fr);gap:28px;">
        <div class="reveal" style="text-align:center;">
          <div style="font-size:10px;letter-spacing:3px;color:#C4A070;margin-bottom:8px;font-weight:500;">01</div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;margin-bottom:6px;">Design</div>
          <p style="font-size:12.5px;color:rgba(232,228,223,0.3);line-height:1.6;margin:0;">Concept sketches and digital CAD modeling</p>
        </div>
        <div class="reveal reveal-d1" style="text-align:center;">
          <div style="font-size:10px;letter-spacing:3px;color:#C4A070;margin-bottom:8px;font-weight:500;">02</div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;margin-bottom:6px;">Material</div>
          <p style="font-size:12.5px;color:rgba(232,228,223,0.3);line-height:1.6;margin:0;">Sourcing quality wood, metal, fabric, and media</p>
        </div>
        <div class="reveal reveal-d2" style="text-align:center;">
          <div style="font-size:10px;letter-spacing:3px;color:#C4A070;margin-bottom:8px;font-weight:500;">03</div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;margin-bottom:6px;">Fabricate</div>
          <p style="font-size:12.5px;color:rgba(232,228,223,0.3);line-height:1.6;margin:0;">CNC machining, laser engraving, and assembly</p>
        </div>
        <div class="reveal reveal-d3" style="text-align:center;">
          <div style="font-size:10px;letter-spacing:3px;color:#C4A070;margin-bottom:8px;font-weight:500;">04</div>
          <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;margin-bottom:6px;">Deliver</div>
          <p style="font-size:12.5px;color:rgba(232,228,223,0.3);line-height:1.6;margin:0;">Quality checked and shipped or ready for pickup</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="section">
    <div class="container" style="text-align:center;">
      <div class="reveal">
        <h2 class="heading-md" style="margin-bottom:14px;">Have a Project in Mind?</h2>
        <p style="font-size:14px;color:rgba(232,228,223,0.35);margin-bottom:28px;">Custom orders, collaborations, and wholesale inquiries welcome.</p>
        <a href="/contact" style="display:inline-block;padding:13px 36px;border-radius:4px;border:1px solid #C4A070;background:transparent;color:#C4A070;font-family:'Outfit',sans-serif;font-size:12.5px;font-weight:500;letter-spacing:2px;text-transform:uppercase;">Get in Touch</a>
      </div>
    </div>
  </section>

  <Footer />
  <RevealScript />
</BaseLayout>
