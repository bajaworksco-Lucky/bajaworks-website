---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import RevealScript from '../components/shared/RevealScript.astro';
import CartDrawer from '../components/shared/CartDrawer.tsx';
import CasaShop from '../components/casa/CasaShop.tsx';
import '../styles/global.css';
---

<BaseLayout title="Casa Baja | Baja Works Co." description="Handcrafted home goods, kids' organizers, pet accessories, and custom gifts. Made from real materials.">
  <Navbar theme="light" />
  <CartDrawer client:load />

  <!-- ═══ HERO — warm dark ═══ -->
  <section style="position:relative;overflow:hidden;background:#2A2520;color:#FAF7F1;padding:72px 0 64px;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse 500px 300px at 75% 30%,rgba(196,160,112,0.15),transparent 50%),radial-gradient(ellipse 400px 250px at 20% 70%,rgba(168,145,122,0.1),transparent 50%);"></div>
    <div style="position:absolute;top:-40px;right:8%;width:280px;height:280px;border-radius:50%;border:1px solid rgba(250,247,241,0.05);"></div>
    <div style="position:absolute;bottom:-60px;left:5%;width:200px;height:200px;border-radius:50%;border:1px solid rgba(250,247,241,0.03);"></div>

    <div class="container" style="position:relative;">
      <div class="reveal" style="display:inline-block;padding:5px 14px;border-radius:3px;background:rgba(196,160,112,0.15);border:1px solid rgba(196,160,112,0.25);font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#C4A070;margin-bottom:22px;font-weight:500;">
        A Baja Works Division
      </div>
      <h1 class="reveal reveal-d1" style="font-family:'Bebas Neue',sans-serif;font-size:clamp(48px,9vw,100px);letter-spacing:3px;line-height:0.9;margin:0 0 18px;">
        CASA BAJA
      </h1>
      <p class="reveal reveal-d2" style="font-size:clamp(15px,1.8vw,18px);line-height:1.65;color:rgba(250,247,241,0.55);max-width:48ch;font-weight:300;">
        Things for your space — wherever life happens. Handcrafted from real materials with the same care we'd put into our own home.
      </p>
    </div>
  </section>

  <!-- ═══ SHOP (React Interactive) ═══ -->
  <div style="background:#FAF7F1;color:#1a1a1a;">
    <CasaShop client:load />
  </div>

  <!-- ═══ CUSTOM CTA ═══ -->
  <section style="padding:56px 0;background:#EDE8E0;border-top:1px solid rgba(26,26,26,0.06);">
    <div style="max-width:700px;margin:0 auto;padding:0 clamp(18px,4vw,40px);text-align:center;">
      <div class="reveal">
        <h2 style="font-family:'Bebas Neue',sans-serif;font-size:clamp(26px,4vw,42px);letter-spacing:2px;margin:0 0 12px;color:#2A2520;">Something Specific?</h2>
        <p style="font-size:14px;color:rgba(26,26,26,0.45);margin-bottom:28px;line-height:1.7;">
          We build custom pieces to order. A personalized gift, a one-off organizer, something that doesn't exist yet — tell us and we'll make it.
        </p>
        <a href="/contact" style="display:inline-block;padding:12px 32px;border-radius:4px;border:2px solid #2A2520;background:transparent;color:#2A2520;font-family:'Outfit',sans-serif;font-size:12.5px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;">Request a Quote</a>
      </div>
    </div>
  </section>

  <Footer />
  <RevealScript />
</BaseLayout>
