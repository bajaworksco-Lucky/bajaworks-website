---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHeader from '../components/home/HomeHeader.astro';
import HomeContact from '../components/home/HomeContact.astro';
import HomeFaq from '../components/home/HomeFaq.astro';
import HomeFooter from '../components/home/HomeFooter.astro';
import HomeRevealScript from '../components/home/HomeRevealScript.astro';
import '../styles/home.css';
---

<BaseLayout
  title="Casa | Baja Works Co."
  description="Casa by Baja Works Co. — home goods with a warm modern vibe. Shelves, organizers, coasters, candle accessories and functional décor built to live with."
>
  <HomeHeader />
  <section class="hero">
    <div class="heroMedia"></div>
    <div class="heroOverlay">
      <div class="heroBadge reveal">
        <h1>Casa</h1>
        <h3>Live with Intention</h3>
        <p>Home goods with a warm modern vibe — shelves, organizers, coasters, candle accessories, and functional décor built to live with.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle reveal">About Casa</h2>
      <div class="introGrid">
        <div class="copyCard reveal">
          <h3>Designed to Enhance Your Space</h3>
          <p>Our Casa collection bridges form and function. Each piece is crafted from natural materials and modern finishes to bring warmth and organization to your home. From wall‑mounted shelves and entryway organizers to coasters and candle accessories, every item is thoughtfully designed to elevate everyday living.</p>
          <p>We believe in pieces that age gracefully and complement any space — because a well‑made home is built one detail at a time.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sectionTitle reveal">Coming Soon</h2>
      <p class="reveal">We’re putting the finishing touches on our first run of home goods. Sign up for updates and be the first to know when Casa products are available.</p>
    </div>
  </section>

  <HomeContact />
  <HomeFaq />
  <HomeFooter />
  <HomeRevealScript />
</BaseLayout>