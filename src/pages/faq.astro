---
// src/pages/faq.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import RevealScript from '../components/shared/RevealScript.astro';
import CartDrawer from '../components/shared/CartDrawer.tsx';
import '../styles/global.css';

const sections = [
  {
    title: 'Ordering & Turnaround',
    items: [
      {
        q: 'How long does it take to make my order?',
        a: 'Ready-made Casa Baja pieces ship within 3–5 business days. Personalized and engraved items take 5–7 business days since each one is made to order. Studio print jobs (posters, canvas, banners) print within 2–4 business days after we receive and approve your artwork. We\'ll confirm your timeline by email when your order comes in — and if you\'re on a deadline for an event, tell us and we\'ll work with you.',
      },
      {
        q: 'Can you rush an order?',
        a: 'Often, yes. Email us at bajaworksco@gmail.com with your order number and your deadline before or right after ordering. Rush availability depends on our current production queue, and a rush fee may apply for jobs that need to jump the line.',
      },
      {
        q: 'How do I pay?',
        a: 'All payments are processed securely through Stripe. We accept all major credit and debit cards. Your card details never touch our servers.',
      },
      {
        q: 'Will I get updates on my order?',
        a: 'Yes. You\'ll get an email confirmation when you order, and another when your piece ships or is ready for pickup. For custom work, we\'ll email you a proof to approve before anything gets cut, engraved, or printed.',
      },
    ],
  },
  {
    title: 'Custom Orders & Artwork',
    items: [
      {
        q: 'How do I send you my artwork or photos?',
        a: 'After checkout, email your files to bajaworksco@gmail.com with your order number in the subject line. For prints and canvas, high-resolution files (300 DPI at print size) give the best results — JPG, PNG, PDF, or TIFF all work. Not sure if your file is good enough? Send it over and we\'ll check it before printing, free.',
      },
      {
        q: 'Can you design something for me from scratch?',
        a: 'Yes. Studio offers full design services — logos, banners, posters, business cards, and complete brand packages. If you have an idea, a sketch, or even just a description, we\'ll turn it into a finished design before producing it. Design-included products are marked on their product pages.',
      },
      {
        q: 'Can you make something that isn\'t on the site?',
        a: 'Almost certainly. We build custom pieces to order on our CNC, laser engraver, and large-format printer. Send us what you\'re thinking through the contact page and we\'ll quote it. One-offs, gifts, small batches, and wholesale runs are all welcome.',
      },
      {
        q: 'Will I see a proof before you make my custom piece?',
        a: 'Yes — every personalized or custom order gets a digital proof by email before production starts. Check spelling, dates, and names carefully; once you approve, we build exactly what\'s on the proof.',
      },
    ],
  },
  {
    title: 'Shipping & Pickup',
    items: [
      {
        q: 'Where do you ship?',
        a: 'We ship anywhere in the United States, and worldwide on request. Shipping cost is calculated at checkout based on size and weight. Posters ship rolled in protective tubes; banners ship rolled, never folded.',
      },
      {
        q: 'Can I pick up my order locally?',
        a: 'Yes — we serve the El Centro and San Diego areas and arrange local pickup by appointment once your order is ready. We operate from a private workshop rather than a storefront, so we\'ll coordinate a pickup time and location with you by email.',
      },
      {
        q: 'My order arrived damaged. What now?',
        a: 'Email us photos of the damage and the packaging at bajaworksco@gmail.com within 7 days of delivery and we\'ll make it right — replacement or refund, your choice. We pack everything carefully, but carriers happen.',
      },
    ],
  },
  {
    title: 'Returns & Care',
    items: [
      {
        q: 'What\'s your return policy?',
        a: 'Non-personalized items can be returned within 30 days in original condition for a refund (buyer covers return shipping). Personalized, engraved, and custom-printed pieces can\'t be returned since they\'re made specifically for you — but if there\'s a defect or we made an error against your approved proof, we\'ll replace it at no cost.',
      },
      {
        q: 'How do I care for my wood piece?',
        a: 'Most pieces just need a wipe with a dry or slightly damp cloth. Cutting and charcuterie boards: hand wash, dry immediately, and re-oil monthly with food-safe mineral oil — never put solid wood in the dishwasher. Each product page lists care instructions specific to that piece.',
      },
      {
        q: 'Are your banners okay outdoors?',
        a: 'Yes — our event banners are printed on tear-resistant scrim media with hemmed edges and metal grommets, rated for indoor and outdoor use. For storage, roll them instead of folding to avoid creases.',
      },
    ],
  },
  {
    title: 'About Baja Works',
    items: [
      {
        q: 'Where are you located?',
        a: 'We\'re based in the El Centro–San Diego corridor of Southern California, between the desert and the coast — the landscape that inspires everything we make. We\'re a service-area workshop, not a retail storefront, and we ship nationwide.',
      },
      {
        q: 'Do you work with businesses?',
        a: 'Absolutely. Banners, signage, business cards, branding packages, and bulk orders for restaurants, real estate, contractors, gyms, and events are a core part of what we do. Reach out through the contact page for wholesale or recurring-order pricing.',
      },
      {
        q: 'Is everything really made by you?',
        a: 'Yes. Every piece is designed, cut, engraved, printed, and finished in our own workshop — CNC machining, laser engraving, 3D printing, and large-format printing, all in-house. No middleman between the idea and the object.',
      },
    ],
  },
];
---

<BaseLayout title="FAQ | Baja Works Co." description="Answers about ordering, turnaround times, shipping, custom work, and returns at Baja Works Co.">
  <Navbar theme="dark" />
  <CartDrawer client:load />

  <!-- Grain -->
  <div class="grain"></div>

  <!-- ═══ HERO ═══ -->
  <section style="position:relative;overflow:hidden;padding:88px 0 64px;border-bottom:1px solid rgba(255,255,255,0.05);">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse 700px 400px at 15% 30%,rgba(196,160,112,0.08),transparent 50%);"></div>
    <div class="container" style="position:relative;z-index:2;">
      <div class="label-accent reveal" style="margin-bottom:24px;">Help & Answers</div>
      <h1 class="heading-xl reveal reveal-d1" style="font-size:clamp(48px,8vw,90px);">FAQ</h1>
      <p class="reveal reveal-d2" style="font-size:clamp(15px,1.8vw,18px);line-height:1.65;color:rgba(232,228,223,0.45);max-width:48ch;margin-top:24px;font-weight:300;">
        Everything you need to know about ordering, turnaround, shipping, and custom work. Don't see your question? <a href="/contact" style="color:#C4A070;text-decoration:none;border-bottom:1px solid rgba(196,160,112,0.4);">Reach out</a> — we answer fast.
      </p>
    </div>
  </section>

  <!-- ═══ FAQ SECTIONS ═══ -->
  <section class="section">
    <div class="container" style="max-width:820px;">
      {sections.map((section, si) => (
        <div style={`margin-bottom:${si === sections.length - 1 ? '0' : '56px'};`}>
          <div class="reveal" style="display:flex;align-items:center;gap:14px;margin-bottom:24px;">
            <span style="font-size:11px;color:#C4A070;letter-spacing:2px;font-weight:500;">{String(si + 1).padStart(2, '0')}</span>
            <h2 style="font-family:'Bebas Neue',sans-serif;font-size:clamp(24px,3.5vw,34px);letter-spacing:2px;margin:0;color:rgba(232,228,223,0.9);">{section.title}</h2>
          </div>

          {section.items.map((item) => (
            <details class="faq-item reveal">
              <summary>
                <span style="flex:1;">{item.q}</span>
                <span class="faq-chevron">+</span>
              </summary>
              <p style="font-size:14.5px;line-height:1.8;color:rgba(232,228,223,0.45);margin:0;padding:0 0 22px;max-width:62ch;">{item.a}</p>
            </details>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section style="padding:72px 0;border-top:1px solid rgba(255,255,255,0.05);text-align:center;">
    <div class="container">
      <h2 class="reveal" style="font-family:'Bebas Neue',sans-serif;font-size:clamp(26px,4vw,42px);letter-spacing:2px;margin:0 0 12px;">Still Have a Question?</h2>
      <p class="reveal reveal-d1" style="font-size:14px;color:rgba(232,228,223,0.4);margin-bottom:28px;line-height:1.7;">
        Email us at bajaworksco@gmail.com or send a message — we usually reply within one business day.
      </p>
      <a href="/contact" class="btn-primary reveal reveal-d2">Get in Touch</a>
    </div>
  </section>

  <Footer />
  <RevealScript />
</BaseLayout>

<style>
  .faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .faq-item summary {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 0;
    cursor: pointer;
    list-style: none;
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: rgba(232, 228, 223, 0.8);
    transition: color 0.2s;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary:hover {
    color: #c4a070;
  }
  .faq-item summary:focus-visible {
    outline: 2px solid #c4a070;
    outline-offset: 4px;
  }
  .faq-chevron {
    font-size: 20px;
    font-weight: 300;
    color: #c4a070;
    transition: transform 0.25s ease;
    line-height: 1;
  }
  .faq-item[open] .faq-chevron {
    transform: rotate(45deg);
  }
  .faq-item[open] summary {
    color: #c4a070;
  }
</style>
