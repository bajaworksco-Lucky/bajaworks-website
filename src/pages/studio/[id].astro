---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/shared/Navbar.astro';
import Footer from '../../components/shared/Footer.astro';
import RevealScript from '../../components/shared/RevealScript.astro';
import CartDrawer from '../../components/shared/CartDrawer.tsx';
import StudioProductDetail from '../../components/studio/StudioProductDetail.tsx';
import products from '../../data/products.json';
import '../../styles/global.css';

export function getStaticPaths() {
  const studioProducts = products.filter((p) => p.division === 'studio');
  return studioProducts.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<BaseLayout title={`${product.name} | Baja Studio`} description={product.description || `${product.name} — produced by Baja Works Co.`}>
  <Navbar theme="light" />
  <CartDrawer client:load />

  <div style="background:#F2F0EC;color:#111;min-height:100vh;">
    <StudioProductDetail client:load product={product} />
  </div>

  <Footer />
  <RevealScript />
</BaseLayout>
