---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/shared/Navbar.astro';
import Footer from '../../components/shared/Footer.astro';
import RevealScript from '../../components/shared/RevealScript.astro';
import CartDrawer from '../../components/shared/CartDrawer.tsx';
import ProductDetail from '../../components/casa/ProductDetail.tsx';
import products from '../../data/products.json';
import '../../styles/global.css';

export function getStaticPaths() {
  const casaProducts = products.filter((p) => p.division === 'casa');
  return casaProducts.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<BaseLayout title={`${product.name} | Casa Baja`} description={product.description || `${product.name} — handcrafted by Baja Works Co.`}>
  <Navbar theme="light" />
  <CartDrawer client:load />

  <div style="background:#FAF7F1;color:#1a1a1a;min-height:100vh;">
    <ProductDetail client:load product={product} />
  </div>

  <Footer />
  <RevealScript />
</BaseLayout>
